# Supabase credentials (get from https://supabase.com dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Frontend (NEXT_PUBLIC_ vars are public, baked at build time)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sync secret (used by cron-jobs.org to trigger sync)
SYNC_SECRET=your-sync-secret

# Path to iptv-master directory
IPTV_MASTER_PATH=../../iptv-master
